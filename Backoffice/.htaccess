RewriteEngine On

# Interdire l'affichage de .php dans l'URL (redirection externe)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.php(?:[\s?]|$) [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Compatibilité anciens chemins sans .php
RewriteRule ^createArticle/?$ /articles/create [R=301,L,NE]
RewriteRule ^createCategory/?$ /categories/create [R=301,L,NE]

RewriteCond %{QUERY_STRING} ^id=([0-9]+)$ [NC]
RewriteRule ^editArticle/?$ /articles/edit/%1? [R=301,L,NE]

RewriteCond %{QUERY_STRING} ^id=([0-9]+)$ [NC]
RewriteRule ^editCategory/?$ /categories/edit/%1? [R=301,L,NE]

# Routes auth / pages simples
RewriteRule ^login/?$ login.php [L,QSA]
RewriteRule ^traitementLogin/?$ traitementLogin.php [L,QSA]
RewriteRule ^logout/?$ logout.php [L,QSA]
RewriteRule ^dashboard/?$ dashboard.php [L,QSA]

# CRUD Articles via un seul fichier
RewriteRule ^articles/?$ articlesCrud.php [L,QSA]
RewriteRule ^articles/create/?$ articlesCrud.php?action=create [L,QSA]
RewriteRule ^articles/edit/([0-9]+)/?$ articlesCrud.php?action=edit&id=$1 [L,QSA]
RewriteRule ^articles/delete/([0-9]+)/?$ articlesCrud.php?action=delete&id=$1 [L,QSA]
RewriteRule ^articles/editor-upload/?$ articlesCrud.php?action=editor-upload [L,QSA]

# CRUD Catégories via un seul fichier
RewriteRule ^categories/?$ categoriesCrud.php [L,QSA]
RewriteRule ^categories/create/?$ categoriesCrud.php?action=create [L,QSA]
RewriteRule ^categories/edit/([0-9]+)/?$ categoriesCrud.php?action=edit&id=$1 [L,QSA]
RewriteRule ^categories/delete/([0-9]+)/?$ categoriesCrud.php?action=delete&id=$1 [L,QSA]

# Laisser passer les vrais fichiers/dossiers (assets, uploads, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Réécriture interne URL propre -> fichier .php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
